<?xml version="1.0"?>
<robot name="fossbot">
  <link name="base_footprint"/>
  <link name="base_link"/>
  <link name="imu"/>
  <link name="imu/imu"/>
  <link name="lidar"/>
  <link name="lidar/scan_omni"/>
  <link name="ultrasonic"/>
  <link name="ultrasonic/ultrasonic"/>
  <link name="camera_front"/>
  <link name="camera_front/color"/>
  <link name="camera_front/depth"/>
  <link name="caster_back"/>
  <link name="wheel_left"/>
  <link name="wheel_right"/>
  
  <!-- JOINTS -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu"/>
    <origin xyz="-0.05 0 0.05" rpy="0 0 0"/>
  </joint>
  
  <joint name="imu_sensor_joint" type="fixed">
    <parent link="imu"/>
    <child link="imu/imu"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar"/>
    <origin xyz="-0.05 0 0.105" rpy="0 0 0"/>
  </joint>
  
  <joint name="lidar_scan_joint" type="fixed">
    <parent link="lidar"/>
    <child link="lidar/scan_omni"/>
    <origin xyz="0 0 0.3" rpy="0 0 0"/>
  </joint>
  
  <joint name="ultrasonic_joint" type="fixed">
    <parent link="base_link"/>
    <child link="ultrasonic"/>
    <origin xyz="0.018 0 0.02" rpy="0 0 0"/>
  </joint>
  
  <joint name="ultrasonic_sensor_joint" type="fixed">
    <parent link="ultrasonic"/>
    <child link="ultrasonic/ultrasonic"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_front"/>
    <origin xyz="0.018 0 0.095" rpy="-1.57 0 -1.57"/>
  </joint>
  
  <joint name="camera_color_joint" type="fixed">
    <parent link="camera_front"/>
    <child link="camera_front/color"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="camera_depth_joint" type="fixed">
    <parent link="camera_front"/>
    <child link="camera_front/depth"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_back"/>
    <origin xyz="-0.11 0 0" rpy="0 0 0"/>
  </joint>
  
  <joint name="wheel_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_left"/>
    <origin xyz="0 0.105 0.023" rpy="-1.57 0 0"/>
  </joint>
  
  <joint name="wheel_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_right"/>
    <origin xyz="0 -0.105 0.023" rpy="-1.57 0 0"/>
  </joint>
</robot>